    const-string v0, "-\u041f\u0440\u043e\u0445\u043e\u0434\u0438\u0442\u044c \u0441\u044e\u0436\u0435\u0442\u043d\u044b\u0439 \u043a\u0432\u0435\u0441\u0442\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u041f\u0440\u043e\u0439\u0442\u0438 \u043a\u0432\u0435\u0441\u0442)\n- \u0412\u044b\u043f\u043e\u043b\u043d\u044f\u0442\u044c \u0435\u0436\u0435\u0434\u043d\u0435\u0432\u043d\u044b\u0435 \u0437\u0430\u0434\u0430\u043d\u0438\u044f \u0443 C\u0438\u043d\u044f\u043a\u0430\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u0421\u0438\u043d\u044f\u043a | \u0415\u0436\u0435\u0434\u043d\u0435\u0432\u043d\u044b\u0435 \u0437\u0430\u0434\u0430\u043d\u0438\u044f)\n- \u0421\u043e\u0431\u0438\u0440\u0430\u0442\u044c \u0438 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0442\u044c \u043f\u043e\u0434\u0430\u0440\u043a\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f\n\u043f\u043e \u0432\u0441\u0435\u0439 \u043a\u0430\u0440\u0442\u0435 \u0440\u0430\u0437 \u0432 \u0447\u0430\u0441.\n- \u0418\u0433\u0440\u0430\u0442\u044c \u0432 \u0441\u043d\u0435\u0436\u043a\u0438 c \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0438\u0433\u0440\u043e\u043a\u0430\u043c\u0438\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u0411\u043b\u0438\u0436\u0430\u0439\u0448\u0435\u0435 \u043c\u0435\u0441\u0442\u043e \u0438\u0433\u0440\u044b\n\u0432 \u0441\u043d\u0435\u0436\u043a\u0438)\n- \u0412\u044b\u0438\u0433\u0440\u044b\u0432\u0430\u0442\u044c \u0432 \u043c\u0438\u043d\u0438-\u0438\u0433\u0440\u0430\u0445\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u041c\u0438\u043d\u0438 \u0438\u0433\u0440\u044b) \u041f\u0440\u043e\u0445\u043e\u0434\u0438\u0442\u044c \u0441\u044e\u0436\u0435\u0442\u043d\u044b\u0439 \u043a\u0432\u0435\u0441\u0442\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u041f\u0440\u043e\u0439\u0442\u0438 \u043a\u0432\u0435\u0441\u0442)\n- \u0412\u044b\u043f\u043e\u043b\u043d\u044f\u0442\u044c \u0435\u0436\u0435\u0434\u043d\u0435\u0432\u043d\u044b\u0435 \u0437\u0430\u0434\u0430\u043d\u0438\u044f \u0443 C\u0438\u043d\u044f\u043a\u0430\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u0421\u0438\u043d\u044f\u043a | \u0415\u0436\u0435\u0434\u043d\u0435\u0432\u043d\u044b\u0435 \u0437\u0430\u0434\u0430\u043d\u0438\u044f)\n- \u0421\u043e\u0431\u0438\u0440\u0430\u0442\u044c \u0438 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0442\u044c \u043f\u043e\u0434\u0430\u0440\u043a\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u044f\u0432\u043b\u044f\u044e\u0442\u0441\u044f\n\u043f\u043e \u0432\u0441\u0435\u0439 \u043a\u0430\u0440\u0442\u0435 \u0440\u0430\u0437 \u0432 \u0447\u0430\u0441.\n- \u0418\u0433\u0440\u0430\u0442\u044c \u0432 \u0441\u043d\u0435\u0436\u043a\u0438 c \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0438\u0433\u0440\u043e\u043a\u0430\u043c\u0438\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u0411\u043b\u0438\u0436\u0430\u0439\u0448\u0435\u0435 \u043c\u0435\u0441\u0442\u043e \u0438\u0433\u0440\u044b\n\u0432 \u0441\u043d\u0435\u0436\u043a\u0438)\n- \u0412\u044b\u0438\u0433\u0440\u044b\u0432\u0430\u0442\u044c \u0432 \u043c\u0438\u043d\u0438-\u0438\u0433\u0440\u0430\u0445\n(\u041c\u0435\u043d\u044e - \u041d\u0430\u0432\u0438\u0433\u0430\u0442\u043e\u0440 - \u041d\u043e\u0432\u044b\u0439 \u0413\u043e\u0434 2024 - \u041c\u0438\u04